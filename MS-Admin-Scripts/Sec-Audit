#Requires -Modules Microsoft.Graph.Identity.DirectoryManagement, Microsoft.Graph.Users, ExchangeOnlineManagement
<#
.SYNOPSIS
    Full Microsoft 365 audit — Tenant, Exchange, Defender, and Inactive Users.

.DESCRIPTION
    Combines:
      01 - Tenant audit      : domains, licenses, admins, password policies, security defaults, user stats
      02 - Exchange audit    : mailboxes, external forwarding, inbox rules, transport rules, shared mailbox sign-in
      04 - Defender audit    : anti-phishing, safe links, safe attachments, anti-malware, DKIM, anti-spam
      08 - Inactive users    : inactive accounts, stale guests, disabled licensed users, license waste

    CIS M365 Benchmark references: 1.1.4, 2.1.1, 2.1.x

.PARAMETER ExportPath
    Directory for CSV exports. Default: .\audit-results

.PARAMETER InactiveDays
    Days without sign-in before a user is flagged as inactive. Default: 90

.EXAMPLE
    # Connect first, then run:
    Connect-MgGraph -Scopes "User.Read.All","Directory.Read.All","Policy.Read.All","AuditLog.Read.All"
    Connect-ExchangeOnline
    .\m365-full-audit.ps1

.EXAMPLE
    .\m365-full-audit.ps1 -ExportPath "C:\Reports\M365" -InactiveDays 60
#>

param(
    [string]$ExportPath   = ".\audit-results",
    [int]   $InactiveDays = 90
)

$ErrorActionPreference = "Continue"
$timestamp   = Get-Date -Format "yyyyMMdd-HHmmss"
$cutoffDate  = (Get-Date).AddDays(-$InactiveDays)

if (-not (Test-Path $ExportPath)) {
    New-Item -ItemType Directory -Path $ExportPath -Force | Out-Null
}

Write-Host "`n========================================" -ForegroundColor Cyan
Write-Host "  M365 Full Audit — $(Get-Date)"          -ForegroundColor Cyan
Write-Host "  Export path : $ExportPath"               -ForegroundColor Cyan
Write-Host "  Inactive threshold : $InactiveDays days" -ForegroundColor Cyan
Write-Host "========================================`n" -ForegroundColor Cyan


# ============================================================
#  SECTION 1 — TENANT AUDIT
# ============================================================
Write-Host "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta
Write-Host "  SECTION 1: Tenant Audit"                 -ForegroundColor Magenta
Write-Host "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta

# 1.1 Organization info
Write-Host "`n[1.1] Organization details..." -ForegroundColor Yellow

$org = Get-MgOrganization
Write-Host "  Tenant          : $($org.DisplayName)"                               -ForegroundColor Cyan
Write-Host "  Tenant ID       : $($org.Id)"                                        -ForegroundColor Cyan
Write-Host "  Verified domains: $($org.VerifiedDomains.Name -join ', ')"           -ForegroundColor Cyan

# 1.2 License inventory
Write-Host "`n[1.2] License inventory..." -ForegroundColor Yellow

$licenses      = Get-MgSubscribedSku
$licenseReport = @()
foreach ($lic in $licenses) {
    $consumed  = $lic.ConsumedUnits
    $total     = $lic.PrepaidUnits.Enabled
    $available = $total - $consumed
    $usage     = if ($total -gt 0) { [math]::Round($consumed / $total * 100) } else { 0 }

    $licenseReport += [PSCustomObject]@{
        SkuPartNumber = $lic.SkuPartNumber
        Total         = $total
        Consumed      = $consumed
        Available     = $available
        UsagePercent  = "$usage%"
    }
    Write-Host "  $($lic.SkuPartNumber): $consumed/$total used ($usage%)" `
        -ForegroundColor $(if ($usage -gt 90) { "Red" } elseif ($usage -gt 70) { "DarkYellow" } else { "Green" })
}
$licenseReport | Export-Csv "$ExportPath\license-inventory-$timestamp.csv" -NoTypeInformation

# 1.3 Global Administrator accounts
Write-Host "`n[1.3] Global Administrator accounts..." -ForegroundColor Yellow

$globalAdminRole = Get-MgDirectoryRole | Where-Object { $_.DisplayName -eq "Global Administrator" }
$globalAdmins    = @()
if ($globalAdminRole) {
    $members = Get-MgDirectoryRoleMember -DirectoryRoleId $globalAdminRole.Id
    foreach ($m in $members) {
        $user = Get-MgUser -UserId $m.Id -Property DisplayName, UserPrincipalName, AccountEnabled, LastSignInDateTime -ErrorAction SilentlyContinue
        if ($user) {
            $globalAdmins += [PSCustomObject]@{
                DisplayName = $user.DisplayName
                UPN         = $user.UserPrincipalName
                Enabled     = $user.AccountEnabled
                LastSignIn  = $user.SignInActivity.LastSignInDateTime
            }
            Write-Host "  - $($user.UserPrincipalName) (Enabled: $($user.AccountEnabled))" `
                -ForegroundColor $(if ($user.AccountEnabled) { "DarkYellow" } else { "Gray" })
        }
    }
}

$adminCount = $globalAdmins.Count
if ($adminCount -gt 5) {
    Write-Host "  [!] $adminCount Global Admins — too many (CIS recommends 2-4)" -ForegroundColor Red
} elseif ($adminCount -lt 2) {
    Write-Host "  [!] Only $adminCount Global Admin — no backup admin"           -ForegroundColor Red
} else {
    Write-Host "  [+] $adminCount Global Admins (within recommended range)"      -ForegroundColor Green
}
$globalAdmins | Export-Csv "$ExportPath\global-admins-$timestamp.csv" -NoTypeInformation

# 1.4 Password policies
Write-Host "`n[1.4] Password policies..." -ForegroundColor Yellow

$authMethods = Get-MgPolicyAuthenticationMethodPolicy -ErrorAction SilentlyContinue
if ($authMethods) {
    Write-Host "  [+] Authentication methods policy retrieved" -ForegroundColor Green
}
$passwordPolicy = $org.PasswordExpirationPolicy
if ($passwordPolicy) {
    Write-Host "  Password policy: $passwordPolicy" -ForegroundColor Cyan
} else {
    Write-Host "  [i] Using default password policies" -ForegroundColor DarkYellow
}

# 1.5 Security Defaults
Write-Host "`n[1.5] Security Defaults status..." -ForegroundColor Yellow

$securityDefaults = Get-MgPolicyIdentitySecurityDefaultEnforcementPolicy -ErrorAction SilentlyContinue
if ($securityDefaults.IsEnabled) {
    Write-Host "  [+] Security Defaults: ENABLED" -ForegroundColor Green
} else {
    Write-Host "  [!] Security Defaults: DISABLED — ensure Conditional Access is configured" -ForegroundColor DarkYellow
}

# 1.6 User statistics
Write-Host "`n[1.6] User statistics..." -ForegroundColor Yellow

$allUsers      = Get-MgUser -All -Property AccountEnabled, UserType, CreationType, DisplayName, UserPrincipalName, SignInActivity, AssignedLicenses, CreatedDateTime
$enabledUsers  = ($allUsers | Where-Object { $_.AccountEnabled }).Count
$disabledUsers = ($allUsers | Where-Object { -not $_.AccountEnabled }).Count
$guestUsers    = ($allUsers | Where-Object { $_.UserType -eq "Guest" }).Count
$totalUsers    = $allUsers.Count

Write-Host "  Total users  : $totalUsers"   -ForegroundColor Cyan
Write-Host "  Enabled      : $enabledUsers" -ForegroundColor Green
Write-Host "  Disabled     : $disabledUsers" `
    -ForegroundColor $(if ($disabledUsers -gt 0) { "DarkYellow" } else { "Green" })
Write-Host "  Guest accounts: $guestUsers" `
    -ForegroundColor $(if ($guestUsers -gt 10) { "DarkYellow" } else { "Green" })

Write-Host "`n[*] Tenant Audit Summary" -ForegroundColor Cyan
Write-Host "  Tenant           : $($org.DisplayName)"
Write-Host "  Licenses         : $($licenseReport.Count) SKUs"
Write-Host "  Global Admins    : $adminCount"
Write-Host "  Total users      : $totalUsers (Enabled: $enabledUsers, Guests: $guestUsers)"
Write-Host "  Security Defaults: $(if ($securityDefaults.IsEnabled) { 'Enabled' } else { 'Disabled' })"


# ============================================================
#  SECTION 2 — EXCHANGE ONLINE AUDIT
# ============================================================
Write-Host "`n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta
Write-Host "  SECTION 2: Exchange Online Audit"        -ForegroundColor Magenta
Write-Host "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta

# 2.1 Mailbox inventory
Write-Host "`n[2.1] Mailbox inventory..." -ForegroundColor Yellow

$mailboxes      = Get-EXOMailbox -ResultSize Unlimited -Properties DisplayName, PrimarySmtpAddress, RecipientTypeDetails, IsShared
$userMailboxes  = $mailboxes | Where-Object { $_.RecipientTypeDetails -eq "UserMailbox" }
$sharedMailboxes = $mailboxes | Where-Object { $_.RecipientTypeDetails -eq "SharedMailbox" }
$roomMailboxes  = $mailboxes | Where-Object { $_.RecipientTypeDetails -eq "RoomMailbox" }

Write-Host "  User mailboxes   : $($userMailboxes.Count)"   -ForegroundColor Cyan
Write-Host "  Shared mailboxes : $($sharedMailboxes.Count)" -ForegroundColor Cyan
Write-Host "  Room mailboxes   : $($roomMailboxes.Count)"   -ForegroundColor Cyan

# 2.2 External forwarding
Write-Host "`n[2.2] External mail forwarding..." -ForegroundColor Yellow

$forwardingMailboxes = @()
foreach ($mbx in $mailboxes) {
    $fwd = Get-EXOMailbox -Identity $mbx.PrimarySmtpAddress `
        -Properties ForwardingSmtpAddress, ForwardingAddress, DeliverToMailboxAndForward `
        -ErrorAction SilentlyContinue
    if ($fwd.ForwardingSmtpAddress -or $fwd.ForwardingAddress) {
        $forwardingMailboxes += [PSCustomObject]@{
            Mailbox           = $fwd.PrimarySmtpAddress
            ForwardingSmtp    = $fwd.ForwardingSmtpAddress
            ForwardingAddress = $fwd.ForwardingAddress
            DeliverAndForward = $fwd.DeliverToMailboxAndForward
        }
        $isExternal = $fwd.ForwardingSmtpAddress -and $fwd.ForwardingSmtpAddress -notmatch (Get-AcceptedDomain).DomainName
        Write-Host "  [!] $($fwd.PrimarySmtpAddress) forwards to $($fwd.ForwardingSmtpAddress)$(if ($isExternal) { ' (EXTERNAL)' })" `
            -ForegroundColor $(if ($isExternal) { "Red" } else { "DarkYellow" })
    }
}

if ($forwardingMailboxes.Count -eq 0) {
    Write-Host "  [+] No mailbox forwarding configured." -ForegroundColor Green
} else {
    Write-Host "  [!] $($forwardingMailboxes.Count) mailboxes with forwarding" -ForegroundColor Red
    $forwardingMailboxes | Export-Csv "$ExportPath\mail-forwarding-$timestamp.csv" -NoTypeInformation
}

# 2.3 Suspicious inbox rules
Write-Host "`n[2.3] Suspicious inbox rules (external forward, delete, move)..." -ForegroundColor Yellow

$suspiciousRules = @()
foreach ($mbx in $userMailboxes | Select-Object -First 100) {
    $rules = Get-InboxRule -Mailbox $mbx.PrimarySmtpAddress -ErrorAction SilentlyContinue
    foreach ($rule in $rules) {
        $isSuspicious = $false
        $reason       = ""

        if ($rule.ForwardTo -or $rule.ForwardAsAttachmentTo -or $rule.RedirectTo) {
            $isSuspicious = $true
            $reason = "Forwards/redirects to: $($rule.ForwardTo)$($rule.ForwardAsAttachmentTo)$($rule.RedirectTo)"
        }
        if ($rule.DeleteMessage -eq $true) {
            $isSuspicious = $true
            $reason += " Deletes messages."
        }
        if ($rule.MoveToFolder -match "RSS|Deleted|Junk" -and $rule.From) {
            $isSuspicious = $true
            $reason += " Moves specific sender to $($rule.MoveToFolder)."
        }

        if ($isSuspicious) {
            $suspiciousRules += [PSCustomObject]@{
                Mailbox  = $mbx.PrimarySmtpAddress
                RuleName = $rule.Name
                Enabled  = $rule.Enabled
                Reason   = $reason
            }
            Write-Host "  [!] $($mbx.PrimarySmtpAddress) — Rule '$($rule.Name)': $reason" -ForegroundColor Red
        }
    }
}

if ($suspiciousRules.Count -eq 0) {
    Write-Host "  [+] No suspicious inbox rules found." -ForegroundColor Green
} else {
    $suspiciousRules | Export-Csv "$ExportPath\suspicious-inbox-rules-$timestamp.csv" -NoTypeInformation
}

# 2.4 Transport rules
Write-Host "`n[2.4] Transport rules audit..." -ForegroundColor Yellow

$transportRules = Get-TransportRule -ErrorAction SilentlyContinue
$externalRules  = @()
foreach ($rule in $transportRules) {
    if ($rule.State -eq "Enabled" -and ($rule.RouteMessageOutboundRequireTls -or $rule.RedirectMessageTo -or $rule.BlindCopyTo)) {
        $externalRules += [PSCustomObject]@{
            Name     = $rule.Name
            State    = $rule.State
            Priority = $rule.Priority
            Action   = $(if ($rule.RedirectMessageTo) { "Redirect: $($rule.RedirectMessageTo)" }
                         elseif ($rule.BlindCopyTo)   { "BCC: $($rule.BlindCopyTo)" }
                         else                          { "TLS Required" })
        }
        Write-Host "  [i] Rule '$($rule.Name)' — $($externalRules[-1].Action)" -ForegroundColor DarkYellow
    }
}
Write-Host "  Total transport rules: $($transportRules.Count)" -ForegroundColor Cyan

# 2.5 Shared mailboxes with direct sign-in
Write-Host "`n[2.5] Shared mailboxes with direct sign-in enabled..." -ForegroundColor Yellow

$sharedSignIn = @()
foreach ($shared in $sharedMailboxes) {
    $user = Get-MgUser -UserId $shared.ExternalDirectoryObjectId -Property AccountEnabled -ErrorAction SilentlyContinue
    if ($user.AccountEnabled) {
        $sharedSignIn += $shared.PrimarySmtpAddress
        Write-Host "  [!] $($shared.PrimarySmtpAddress) — direct sign-in ENABLED (should be disabled)" -ForegroundColor Red
    }
}
if ($sharedSignIn.Count -eq 0) {
    Write-Host "  [+] All shared mailboxes have direct sign-in disabled." -ForegroundColor Green
}

Write-Host "`n[*] Exchange Audit Summary" -ForegroundColor Cyan
Write-Host "  Total mailboxes      : $($mailboxes.Count)"
Write-Host "  Forwarding configured: $($forwardingMailboxes.Count)"
Write-Host "  Suspicious rules     : $($suspiciousRules.Count)"
Write-Host "  Shared with sign-in  : $($sharedSignIn.Count)"


# ============================================================
#  SECTION 3 — DEFENDER FOR OFFICE 365 AUDIT
# ============================================================
Write-Host "`n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta
Write-Host "  SECTION 3: Defender for Office 365 Audit"       -ForegroundColor Magenta
Write-Host "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta

# 3.1 Anti-Phishing policies
Write-Host "`n[3.1] Anti-Phishing policies..." -ForegroundColor Yellow

$antiPhish = Get-AntiPhishPolicy -ErrorAction SilentlyContinue
foreach ($policy in $antiPhish) {
    Write-Host "  Policy: $($policy.Name)" -ForegroundColor Cyan
    Write-Host "    Impersonation protection : $(if ($policy.EnableTargetedUserProtection) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.EnableTargetedUserProtection) { "Green" } else { "Red" })
    Write-Host "    Domain protection        : $(if ($policy.EnableTargetedDomainsProtection) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.EnableTargetedDomainsProtection) { "Green" } else { "Red" })
    Write-Host "    Mailbox intelligence     : $(if ($policy.EnableMailboxIntelligence) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.EnableMailboxIntelligence) { "Green" } else { "Red" })
    Write-Host "    Spoof intelligence       : $(if ($policy.EnableSpoofIntelligence) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.EnableSpoofIntelligence) { "Green" } else { "Red" })
}

# 3.2 Safe Links policies
Write-Host "`n[3.2] Safe Links policies..." -ForegroundColor Yellow

$safeLinks = Get-SafeLinksPolicy -ErrorAction SilentlyContinue
if ($safeLinks) {
    foreach ($policy in $safeLinks) {
        Write-Host "  Policy: $($policy.Name)" -ForegroundColor Cyan
        Write-Host "    URL scanning  : $(if ($policy.IsEnabled) { 'ON' } else { 'OFF' })" `
            -ForegroundColor $(if ($policy.IsEnabled) { "Green" } else { "Red" })
        Write-Host "    Real-time scan: $(if ($policy.ScanUrls) { 'ON' } else { 'OFF' })" `
            -ForegroundColor $(if ($policy.ScanUrls) { "Green" } else { "Red" })
        Write-Host "    Track clicks  : $(if ($policy.TrackClicks) { 'ON' } else { 'OFF' })" -ForegroundColor Green
    }
} else {
    Write-Host "  [!] No Safe Links policies found — Defender for O365 may not be licensed" -ForegroundColor Red
}

# 3.3 Safe Attachments policies
Write-Host "`n[3.3] Safe Attachments policies..." -ForegroundColor Yellow

$safeAttach = Get-SafeAttachmentPolicy -ErrorAction SilentlyContinue
if ($safeAttach) {
    foreach ($policy in $safeAttach) {
        Write-Host "  Policy: $($policy.Name)" -ForegroundColor Cyan
        Write-Host "    Action : $($policy.Action)" `
            -ForegroundColor $(if ($policy.Action -eq "Block") { "Green" } else { "DarkYellow" })
        Write-Host "    Enabled: $($policy.Enable)" `
            -ForegroundColor $(if ($policy.Enable) { "Green" } else { "Red" })
    }
} else {
    Write-Host "  [!] No Safe Attachments policies found" -ForegroundColor Red
}

# 3.4 Anti-Malware policies
Write-Host "`n[3.4] Anti-Malware policies..." -ForegroundColor Yellow

$antiMalware = Get-MalwareFilterPolicy -ErrorAction SilentlyContinue
foreach ($policy in $antiMalware) {
    Write-Host "  Policy: $($policy.Name)" -ForegroundColor Cyan
    Write-Host "    File type filter: $(if ($policy.EnableFileFilter) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.EnableFileFilter) { "Green" } else { "Red" })
    Write-Host "    ZAP enabled     : $(if ($policy.ZapEnabled) { 'ON' } else { 'OFF' })" `
        -ForegroundColor $(if ($policy.ZapEnabled) { "Green" } else { "Red" })
    if ($policy.FileTypes) {
        Write-Host "    Blocked types   : $($policy.FileTypes.Count) extensions" -ForegroundColor Cyan
    }
}

# 3.5 DKIM status
Write-Host "`n[3.5] DKIM signing status..." -ForegroundColor Yellow

$dkim = Get-DkimSigningConfig -ErrorAction SilentlyContinue
foreach ($d in $dkim) {
    Write-Host "  $($d.Domain) : $(if ($d.Enabled) { 'ENABLED' } else { 'DISABLED' })" `
        -ForegroundColor $(if ($d.Enabled) { "Green" } else { "Red" })
}

# 3.6 Anti-Spam policies
Write-Host "`n[3.6] Anti-Spam policies..." -ForegroundColor Yellow

$antiSpam = Get-HostedContentFilterPolicy -ErrorAction SilentlyContinue
foreach ($policy in $antiSpam) {
    Write-Host "  Policy: $($policy.Name)"                          -ForegroundColor Cyan
    Write-Host "    Spam action     : $($policy.SpamAction)"        -ForegroundColor Cyan
    Write-Host "    High conf spam  : $($policy.HighConfidenceSpamAction)" -ForegroundColor Cyan
    Write-Host "    Phish action    : $($policy.PhishSpamAction)"   -ForegroundColor Cyan
    Write-Host "    Bulk threshold  : $($policy.BulkThreshold)"     -ForegroundColor Cyan
}

Write-Host "`n[*] Defender Audit Summary" -ForegroundColor Cyan
Write-Host "  Anti-Phishing policies    : $(if ($antiPhish)   { $antiPhish.Count }   else { 0 })"
Write-Host "  Safe Links policies       : $(if ($safeLinks)   { $safeLinks.Count }   else { 0 })"
Write-Host "  Safe Attachments policies : $(if ($safeAttach)  { $safeAttach.Count }  else { 0 })"
Write-Host "  DKIM domains configured   : $(if ($dkim)        { $dkim.Count }        else { 0 })"


# ============================================================
#  SECTION 4 — INACTIVE USERS AUDIT
# ============================================================
Write-Host "`n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta
Write-Host "  SECTION 4: Inactive Users Audit"         -ForegroundColor Magenta
Write-Host "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" -ForegroundColor Magenta
Write-Host "  Threshold: $InactiveDays days (before $($cutoffDate.ToString('yyyy-MM-dd')))" -ForegroundColor Cyan

# Note: $allUsers was already fetched in Section 1 with all required properties.

# 4.1 Inactive / never signed-in users
Write-Host "`n[4.1] Users with no sign-in in $InactiveDays days..." -ForegroundColor Yellow

$inactiveUsers  = @()
$neverSignedIn  = @()

foreach ($user in $allUsers) {
    $lastSignIn = $user.SignInActivity.LastSignInDateTime

    if (-not $lastSignIn -and $user.AccountEnabled) {
        $neverSignedIn += [PSCustomObject]@{
            DisplayName = $user.DisplayName
            UPN         = $user.UserPrincipalName
            UserType    = $user.UserType
            Created     = $user.CreatedDateTime
            Licensed    = ($user.AssignedLicenses.Count -gt 0)
        }
    } elseif ($lastSignIn -and $lastSignIn -lt $cutoffDate -and $user.AccountEnabled) {
        $daysSince = ((Get-Date) - $lastSignIn).Days
        $inactiveUsers += [PSCustomObject]@{
            DisplayName  = $user.DisplayName
            UPN          = $user.UserPrincipalName
            UserType     = $user.UserType
            LastSignIn   = $lastSignIn
            DaysInactive = $daysSince
            Licensed     = ($user.AssignedLicenses.Count -gt 0)
        }
    }
}

Write-Host "  [!] $($inactiveUsers.Count) inactive users (>$InactiveDays days)" `
    -ForegroundColor $(if ($inactiveUsers.Count -gt 0) { "Red" } else { "Green" })
Write-Host "  [!] $($neverSignedIn.Count) enabled users never signed in" `
    -ForegroundColor $(if ($neverSignedIn.Count -gt 0) { "DarkYellow" } else { "Green" })

if ($inactiveUsers.Count -gt 0) {
    foreach ($u in $inactiveUsers | Sort-Object DaysInactive -Descending | Select-Object -First 15) {
        Write-Host "    - $($u.UPN) — $($u.DaysInactive) days inactive$(if ($u.Licensed) { ' [LICENSED]' })" -ForegroundColor Red
    }
    $inactiveUsers | Export-Csv "$ExportPath\inactive-users-$timestamp.csv" -NoTypeInformation
}

# 4.2 Stale guest accounts
Write-Host "`n[4.2] Stale guest accounts..." -ForegroundColor Yellow

$guests      = $allUsers | Where-Object { $_.UserType -eq "Guest" }
$staleGuests = @()

foreach ($guest in $guests) {
    $lastSignIn = $guest.SignInActivity.LastSignInDateTime
    if (-not $lastSignIn -or $lastSignIn -lt $cutoffDate) {
        $staleGuests += [PSCustomObject]@{
            DisplayName = $guest.DisplayName
            UPN         = $guest.UserPrincipalName
            LastSignIn  = $lastSignIn
            Created     = $guest.CreatedDateTime
        }
    }
}

Write-Host "  Total guests           : $($guests.Count)"   -ForegroundColor Cyan
Write-Host "  Stale guests (>$InactiveDays d): $($staleGuests.Count)" `
    -ForegroundColor $(if ($staleGuests.Count -gt 0) { "Red" } else { "Green" })

if ($staleGuests.Count -gt 0) {
    $staleGuests | Export-Csv "$ExportPath\stale-guests-$timestamp.csv" -NoTypeInformation
}

# 4.3 Disabled users with licenses
Write-Host "`n[4.3] Disabled users still consuming licenses..." -ForegroundColor Yellow

$disabledLicensed = $allUsers | Where-Object {
    -not $_.AccountEnabled -and $_.AssignedLicenses.Count -gt 0
}

if ($disabledLicensed) {
    Write-Host "  [!] $($disabledLicensed.Count) disabled users with active licenses:" -ForegroundColor Red
    foreach ($d in $disabledLicensed | Select-Object -First 10) {
        Write-Host "    - $($d.UserPrincipalName) ($($d.AssignedLicenses.Count) licenses)" -ForegroundColor Red
    }
    $disabledLicensed |
        Select-Object DisplayName, UserPrincipalName, @{ N = 'LicenseCount'; E = { $_.AssignedLicenses.Count } } |
        Export-Csv "$ExportPath\disabled-with-licenses-$timestamp.csv" -NoTypeInformation
} else {
    Write-Host "  [+] No disabled users consuming licenses." -ForegroundColor Green
}

# 4.4 License waste estimation
Write-Host "`n[4.4] License cost estimation..." -ForegroundColor Yellow

$wastedLicenses = 0
if ($disabledLicensed) { $wastedLicenses += ($disabledLicensed | Measure-Object).Count }
if ($inactiveUsers)    { $wastedLicenses += ($inactiveUsers | Where-Object { $_.Licensed } | Measure-Object).Count }

$estimatedWaste = $wastedLicenses * 12  # Rough estimate ~12 EUR/user/month
Write-Host "  Estimated wasted licenses: $wastedLicenses" `
    -ForegroundColor $(if ($wastedLicenses -gt 0) { "Red" } else { "Green" })
Write-Host "  Estimated monthly cost   : ~$estimatedWaste EUR/month" `
    -ForegroundColor $(if ($wastedLicenses -gt 0) { "Red" } else { "Green" })

Write-Host "`n[*] Inactive Users Summary" -ForegroundColor Cyan
Write-Host "  Inactive (>$InactiveDays days): $($inactiveUsers.Count)"
Write-Host "  Never signed in        : $($neverSignedIn.Count)"
Write-Host "  Stale guests           : $($staleGuests.Count)"
